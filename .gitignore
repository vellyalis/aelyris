# Dependencies
node_modules/
target/
target-*/

# Build output
dist/
artifacts/
src-tauri/target/
src-tauri/target-*/
src-tauri/pty-server/target/
src-tauri/binaries/

# Environment
.env*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Tauri
src-tauri/WixTools/
src-tauri/target/

# SQLite
*.db
*.db-journal
*.db-wal

# Logs
*.log

# Cache
.turbo/
.cache/
.codex-auto/
.codex-ui-*.png

# Local Codex handoff state
AGENT_STATE.md

# Playwright
test-results/
playwright-report/
.playwright-mcp/
# Ad-hoc screenshots from Playwright MCP saved at repo root
/*-page.png
/aelyris-*.png
/after-*.png
/no-*.png
/settings-*.png

# Claude Code runtime state (local to each developer)
# .claude/launch.json is tracked as a generic dev-launch template.
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json
# Nested copies (e.g. src-tauri/.claude/settings.local.json when claude
# is launched from a subdirectory). Without this gitignore line, gitignore's
# slash-containing patterns only match at the repo root and per-developer
# MCP server preferences would leak into the patch.
**/.claude/settings.local.json

# Aelyris-specific Claude skills are intentionally trackable when reviewed.
# Do not add generic external skill packs, hooks, or slash commands wholesale.

# Auto-updater signing material (generated by scripts/setup-updater-keys.mjs)
# The private key MUST stay out of the repo; pubkey lives in tauri.conf.json.
.aelyris-updater/

# Ad-hoc, throwaway investigation/demo scripts (not deterministic verifiers).
# These are local debugging aids and must not be published or treated as
# release evidence. Promote anything durable into a named scripts/verify-*.mjs.
scripts/probe-*.mjs
scripts/shot-*.mjs
scripts/raise-opacity-demo.mjs
scripts/set-opacity-direct.mjs

# Defense-in-depth: never allow credential/key material to be committed even via
# `git add -f`. The real signing key lives in the already-ignored .aelyris-updater/.
*.pem
*.key
*.pfx
*.p12
id_rsa*
.npmrc
.netrc

# Test/coverage output and toolchain caches.
coverage/
.nyc_output/
.eslintcache
*.tsbuildinfo
.pnpm-store/

# Internal-only working docs kept local for dev (planning notes, handoffs,
# and gap/audit drafts). These are not published. Historical docs and local
# skill packs stay ignored as well.
docs/history/
.claude/skills/
PLAN.md
docs/specs/*_HANDOFF.md
docs/specs/*_GAP_*.md
*.orig
