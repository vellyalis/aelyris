# Dependencies
node_modules/
target/
target-*/

# Build output
dist/
artifacts/
src-tauri/target/
src-tauri/target-*/
src-tauri/binaries/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Tauri
src-tauri/WixTools/
src-tauri/target/

# SQLite
*.db
*.db-journal
*.db-wal

# Logs
*.log

# Cache
.turbo/
.cache/
.codex-auto/
.codex-ui-*.png

# Local Codex handoff state
AGENT_STATE.md

# Playwright
test-results/
playwright-report/
.playwright-mcp/
# Ad-hoc screenshots from Playwright MCP saved at repo root
/*-page.png
/aether-*.png
/after-*.png
/no-*.png
/settings-*.png

# Claude Code runtime state (local to each developer)
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json
# Nested copies (e.g. src-tauri/.claude/settings.local.json when claude
# is launched from a subdirectory). Without this gitignore line, gitignore's
# slash-containing patterns only match at the repo root and per-developer
# MCP server preferences would leak into the patch.
**/.claude/settings.local.json

# Auto-updater signing material (generated by scripts/setup-updater-keys.mjs)
# The private key MUST stay out of the repo; pubkey lives in tauri.conf.json.
.aether-updater/
