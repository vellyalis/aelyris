{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether Terminal",
  "version": "0.2.3",
  "identifier": "com.aether.terminal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aether Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 560,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* ws://localhost:* https://localhost:*; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Aether",
    "copyright": "Copyright (c) 2026 Aether",
    "shortDescription": "Aether Terminal",
    "longDescription": "Windows-native AI workspace terminal — project-first, Tauri + React, native Rust terminal engine.",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.aether.invalid/{{target}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_VIA_SCRIPTS_SETUP_UPDATER_KEYS",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
