{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether Terminal",
  "mainBinaryName": "Aether",
  "version": "0.2.3",
  "identifier": "com.aether.terminal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aether Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 560,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "visible": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; connect-src 'self' http://localhost:* ws://localhost:* https://localhost:* http://127.0.0.1:* ws://127.0.0.1:* https://127.0.0.1:* http://ipc.localhost https://ipc.localhost; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Aether",
    "copyright": "Copyright (c) 2026 Aether",
    "shortDescription": "Aether Terminal",
    "longDescription": "Windows-native AI workspace terminal — project-first, Tauri + React, native Rust terminal engine.",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.aether-terminal.app/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1MTE0REZDREY1MDAzQ0QKUldUTkExRGYvRTBSdGJOc3BmMDkvcVZnallISkE4QTZUOEc5TE9RUXVJRWgxNVVoU1VwYi8zelYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
