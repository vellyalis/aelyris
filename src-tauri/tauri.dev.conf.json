{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "Aether Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 560,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "state": "active"
        },
        "additionalBrowserArgs": "--remote-debugging-port=9222 --remote-allow-origins=*"
      }
    ]
  }
}
